[Unit]
Description=QRM Rack UI and Backend
After=network.target

[Service]
Type=simple
User=bert
Group=bert
WorkingDirectory=/var/www/qrm-ui
ExecStart=/bin/bash /var/www/qrm-ui/deploy/linux/start.sh
Restart=on-failure
RestartSec=5
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=qrm-service

[Install]
WantedBy=multi-user.target
